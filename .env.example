# 沈家本研究院官网 - 环境变量配置
# 复制此文件为 .env 并修改配置

# 调试模式（生产环境设为 false）
DEBUG=false

# 密钥（生产环境请更改为随机字符串）
SECRET_KEY=shenjiaben-institute-2026-production-key-change-me

# 服务器配置
HOST=0.0.0.0
PORT=5000

# 数据库连接（默认 SQLite）
# DATABASE_URL=sqlite:///data/shenjiaben.db
# 如需 MySQL: DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/shenjiaben

# 日志级别
LOG_LEVEL=INFO

# CORS（生产环境改为具体域名）
CORS_ORIGINS=*

# 合规信息
ICP_NUMBER=ICP备案号：待备案
COPYRIGHT_YEAR=2026
FEEDBACK_EMAIL=feedback@shenjiaben.org
